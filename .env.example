# ============================================================
# .env.example — Environment Variables Template
# ============================================================
# Copy this file and rename it to .env:
#   cp .env.example .env
#
# Then fill in your actual values.
# NEVER commit your real .env file to Git!
# ============================================================

# ---- Server Configuration ----
# The port the Express server listens on
# Cloud platforms (Render, Railway) set this automatically
PORT=3000

# ---- Database Configuration ----
# For Docker: DB_HOST=db (the Docker service name)
# For local: DB_HOST=localhost
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=voteapp

# ---- Voting Configuration ----
# How many seconds to wait before voting opens (countdown timer)
VOTING_DELAY_SECONDS=10

# How many seconds voting stays open (after the countdown ends)
VOTING_DURATION_SECONDS=120
